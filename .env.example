# Server Configuration
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://mama-oliech.vercel.app

# Database Settings (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=hotel_db
DB_CONNECTION_LIMIT=20

# Authentication / JWT
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d
STAFF_PIN_HASH=999d493321747978b55c854adccc47234a0709a2cc854bc02df8c8319518fc41

# Payment Gateway (Stripe Example)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Service (SendGrid Example)
SENDGRID_API_KEY=SG.example_sendgrid_key_goes_here
EMAIL_FROM=reservations@yourhotel.com
EMAIL_SUPPORT=support@yourhotel.com

# Safaricom Lipa Na M-Pesa API Settings
MPESA_CONSUMER_KEY=your_safaricom_developer_consumer_key_here
MPESA_CONSUMER_SECRET=your_safaricom_developer_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=https://your-domain.vercel.app/api/payments/callback
MPESA_CALLBACK_SECRET=your_secure_merchant_token_here

# Admin Seed Credentials
SEED_ADMIN_USER=admin
SEED_ADMIN_PASS=Password123!
